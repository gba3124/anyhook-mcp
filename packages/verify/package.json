{
  "name": "anyhook-verify",
  "version": "0.1.0",
  "type": "module",
  "description": "Verify Anyhook-Signature webhook deliveries \u2014 Web Crypto, zero runtime deps, works in Node / Bun / Deno / Cloudflare Workers / Vercel Edge.",
  "license": "Apache-2.0",
  "author": "Owen Cheng",
  "homepage": "https://anyhook.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/gba3124/anyhook-mcp.git",
    "directory": "packages/verify"
  },
  "bugs": {
    "url": "https://github.com/gba3124/anyhook-mcp/issues"
  },
  "keywords": [
    "webhook",
    "webhook-signature",
    "hmac",
    "anyhook",
    "verify",
    "stripe-compatible",
    "edge",
    "cloudflare-workers"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
