{
  "name": "anyhook-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "AnyHook MCP server \u2014 gives AI agents eyes on webhooks (inspect, replay, mock, verify) for Stripe, GitHub, OpenAI, Anthropic, LangChain, and more.",
  "license": "Apache-2.0",
  "author": "Owen Cheng",
  "homepage": "https://anyhook.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/gba3124/anyhook-mcp.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/gba3124/anyhook-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "webhook",
    "webhooks",
    "claude",
    "cursor",
    "ai-agent",
    "stripe",
    "github",
    "anthropic",
    "openai",
    "langchain"
  ],
  "mcpName": "io.github.gba3124/mcp",
  "bin": {
    "anyhook-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anyhook/core": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
